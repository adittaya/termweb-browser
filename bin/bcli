#!/usr/bin/env bash
# ─── BCLI — Terminal Interactive Browser ───────────────────────────────────
# Global command that connects to the TermWeb server and displays the
# browser screen in your terminal with full mouse/keyboard control.
#
# Usage:
#   bcli                    — connect to ws://127.0.0.1:9222/browser
#   bcli --connect ws://... — connect to custom server
#   bcli --server           — start the background server first, then connect
#   bcli --help             — show full help
#
# First run will build the Rust client automatically.
# ────────────────────────────────────────────────────────────────────────────

set -e

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CLIENT_DIR="$REPO_DIR/client-rs"
BINARY="$CLIENT_DIR/target/release/bcli"
CARGO="$(command -v cargo || true)"

# ─── Help ───────────────────────────────────────────────────────────────────
if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
  echo "BCLI — Terminal Browser & Automation Tool"
  echo ""
  echo "USAGE:"
  echo "  bcli                          Interactive TUI (text mode)"
  echo "  bcli --graphical              Interactive TUI (graphical screenshot mode)"
  echo "  bcli -c ws://HOST:PORT        Connect to custom server address"
  echo "  bcli --server                 Start server daemon + connect"
  echo ""
  echo "CLI COMMANDS (non-interactive):"
  echo "  bcli nav <url>                Navigate to a URL"
  echo "  bcli text                     Extract page text content"
  echo "  bcli links                    Extract all links with hrefs"
  echo "  bcli elements                 Extract interactive elements"
  echo "  bcli click <selector>         Click element by CSS selector"
  echo "  bcli click --x 100 --y 200    Click at pixel coordinates"
  echo "  bcli type <text>              Type text into focused element"
  echo "  bcli type --sel <s> <text>    Click element then type"
  echo "  bcli scroll [px]              Scroll page (default: 300px)"
  echo "  bcli eval '<code>'            Execute JavaScript"
  echo "  bcli screenshot [path]        Take screenshot to file"
  echo "  bcli status                   Session and page status"
  echo "  bcli back                     Go back in history"
  echo "  bcli forward                  Go forward in history"
  echo "  bcli wait <ms>                Wait N milliseconds"
  echo "  bcli find <text>              Find text in page"
  echo "  bcli session <action>         Manage session (create|destroy|status)"
  echo ""
  echo "INTERACTIVE CONTROLS (text mode):"
  echo "  Arrow keys       — Navigate elements / scroll text"
  echo "  Enter            — Click focused element or enter typing mode"
  echo "  Tab/Shift+Tab    — Cycle focus between elements"
  echo "  Left/Right       — Same-row element navigation"
  echo "  Esc              — Clear focus"
  echo "  Ctrl+L           — Enter URL to navigate"
  echo "  Ctrl+F           — Find in page"
  echo "  Ctrl+B / Alt+←  — Go back"
  echo "  Ctrl+N / Alt+→  — Go forward"
  echo "  Ctrl+0           — Toggle Browser Mode (settings panel)"
  echo "  Ctrl+R           — Refresh screenshot"
  echo "  Ctrl+T           — New tab"
  echo "  Ctrl+W           — Close tab"
  echo "  Ctrl+1-9         — Switch tab"
  echo "  Ctrl+C           — Disconnect (server keeps running)"
  echo ""
  echo "SERVER:  node $REPO_DIR/server/index.js --url https://example.com"
  echo "CLIENT:  The Rust binary will be auto-built on first run."
  exit 0
fi

# ─── Build if missing ───────────────────────────────────────────────────────
if [[ ! -x "$BINARY" ]]; then
  echo "[bcli] Building Rust client (first run)..."
  if [[ -z "$CARGO" ]]; then
    echo "[bcli] ERROR: Rust/Cargo not found. Install Rust: https://rustup.rs"
    exit 1
  fi
  cd "$CLIENT_DIR" && cargo build --release 2>&1 | sed 's/^/       /'
  echo "[bcli] Build complete."
fi

# ─── Optional: start server daemon ──────────────────────────────────────────
if [[ "$1" == "--server" ]]; then
  shift
  URL="${1:-https://example.com}"
  echo "[bcli] Starting background server..."
  set -- -u "$URL"
  node "$REPO_DIR/server/index.js" --url "$URL" &
  SERVER_PID=$!
  echo "[bcli] Server PID: $SERVER_PID"
  sleep 2
  trap "kill $SERVER_PID 2>/dev/null; exit" INT TERM EXIT
fi

# ─── Run ────────────────────────────────────────────────────────────────────
exec "$BINARY" "$@"
